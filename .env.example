# =================================
# SweetPOS Environment Configuration
# =================================

# API Server
API_PORT=3000
API_HOST=0.0.0.0
NODE_ENV=development

# PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=sweetpos
DB_PASSWORD=sweetpos_dev_password
DB_DATABASE=sweetpos

# JWT
JWT_ACCESS_SECRET=your-access-secret-change-in-production
JWT_REFRESH_SECRET=your-refresh-secret-change-in-production
JWT_ACCESS_EXPIRY=8h
JWT_REFRESH_EXPIRY=7d

# Rate Limiting
THROTTLE_TTL=60000
THROTTLE_LIMIT=100

# Cloud Sync
SYNC_INTERVAL_MS=30000
SYNC_BATCH_SIZE=100

# Shop Configuration
SHOP_NAME=Sweet Delight
SHOP_ADDRESS=123 Main Street, Colombo
SHOP_PHONE=+94-XX-XXXXXXX
CURRENCY=LKR
TAX_RATE=0

# S3 (for backups and images)
AWS_REGION=ap-south-1
AWS_S3_BUCKET=sweetpos-storage
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
